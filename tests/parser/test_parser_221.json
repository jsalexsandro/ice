  "code": "class Pipeline {\n    public id: string\n    public threshold: int\n    constructor(id: string, weights: int[], threshold: int) {\n        this.id = id\n        this.threshold = threshold\n    }\n    run(matrix: int[][]): string {\n        val total = 0\n        try {\n            if (matrix.length == 0) { throw new Error(\"empty matrix\") }\n            val rowResult = matrix[0][0]\n            total = total + rowResult\n        } catch (e: Error) {\n            total = 0\n        }\n        return <div id={this.id} data-total={total}>{this.id}</div>\n    }\n}",
