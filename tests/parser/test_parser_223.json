  "id": "parser_223",
  "reference": "arquivo parser.test.md - teste 223",
  "description": "func processData com try-catch aninhado em while",
  "code": "func processData(values: int[], threshold: int): int {\n    val total = 0\n    val i = 0\n\n    try {\n        while (i < values.length) {\n            try {\n                val item = values[i] * threshold - values[0]\n                if (item < 0) {\n                    throw new Error(\"negative item\")\n                }\n                if (item > threshold * values.length) {\n                    break\n                }\n                total = total + item\n                i = i + 1\n            } catch (e: RangeError) {\n                i = i + 1\n                continue\n            } catch (e: Error) {\n                throw new Error(\"wrapped\")\n            } finally {\n                val checked = i < values.length\n            }\n        }\n    } catch (e: Error) {\n        try {\n            total = values[0] * threshold\n            if (total < 0) {\n                throw \"fallback failed\"\n            }\n        } catch (inner: Error) {\n            total = 0\n        } catch {\n            total = -1\n        } finally {\n            val recovered = total >= 0\n        }\n    } finally {\n        val done = total >= 0 && i <= values.length\n    }\n\n    return total\n}",
